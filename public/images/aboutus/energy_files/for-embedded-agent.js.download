  display: flex;
  flex-wrap: nowrap;
  align-items: stretch;
  width: 100%;
  border-radius: 4px;

  &:not(:first-child) {
    margin-top: 13px;
  }

  overflow: hidden;

  > div {
    position: relative;
    background: ${e=>"warning"===e.mode?"#F5A51C":"#0099FF"};
    width: 49px;

    svg {
      fill: white;
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      width: 24px;
      height: 24px;
    }

    & + div {
      display: flex;
      flex: 1;
      flex-direction: column;
      align-items: flex-start;
